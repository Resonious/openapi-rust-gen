{
  "openapi": "3.0.0",
  "info": { "title": "Basic Types", "version": "1.0.0" },
  "paths": {
    "/widgets": {
      "get": {
        "operationId": "listWidgets",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Widget" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createWidget",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWidget" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Widget" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Widget": {
        "type": "object",
        "required": ["id", "name", "count", "weight", "active"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "count": { "type": "integer", "format": "int32" },
          "weight": { "type": "number" },
          "active": { "type": "boolean" },
          "description": { "type": "string" },
          "small_id": { "type": "integer", "format": "int16" },
          "big_id": { "type": "integer", "format": "uint64" },
          "tiny": { "type": "integer", "format": "int8" },
          "utiny": { "type": "integer", "format": "uint8" }
        }
      },
      "CreateWidget": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "count": { "type": "integer", "format": "int32" },
          "weight": { "type": "number" },
          "active": { "type": "boolean" }
        }
      }
    }
  }
}
